## figures for paper 
Plot_gene <- function(x, name){
  data=plotCounts(dds, gene = x, intgroup = 'condition', returnData = T)
  p=ggplot(data, aes(x=factor(condition, levels = c('control', 'low', 'high', 'extra')), y=count, fill=factor(condition, levels = c('control', 'low', 'high', 'extra'))))+
    ggtitle(paste0(x, ' - ', name))+
    geom_boxplot()+
    ylab('Normalised expression')+
    # Change labs here
    scale_x_discrete(labels= c('0', '0.1', '1','10')) +
    # Custom colours here
    scale_fill_manual(values = c('gray40','#FF6A6A','#4876FF','#DBDBDB'))+
    xlab('3-HK (µM)')+
    geom_point(size = 3)+
    theme_minimal()+
    theme(legend.position = 'none', title = element_text(size = 12), axis.text = element_text(size=10))
  return(p)
}

Plot_gene('NM_001278463', 'DNM1L')
